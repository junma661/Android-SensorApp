<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_history_data"
        android:textSize="22sp"
        android:layout_gravity="center_horizontal"/>

    <Spinner
        android:id="@+id/sp_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"/>

    <TextView
        android:id="@+id/tv_empty_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tip_empty_data"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- 导出CSV按钮 -->
    <ListView
        android:id="@+id/lv_data"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginVertical="16dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btn_export_csv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_export_csv"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_back_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_back_home"/>
    <Button
        android:id="@+id/btn_test_provider"
        android:text="测试读取Provider数据"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>