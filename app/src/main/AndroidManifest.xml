<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.sensorrecorder">

    <!-- 通知权限：光线超限告警、CSV导出完成通知（Android13+） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- 前台后台采集服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!-- 外部存储读写（仅适配Android12及以下） -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <!-- 全文件访问权限，解决低版本导出文件失败 -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        android:maxSdkVersion="34"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sensorrecorder">

        <!-- 实验要求：ContentProvider 数据共享组件 -->
        <provider
            android:name=".SensorContentProvider"
            android:authorities="com.example.sensorrecorder.provider"
            android:exported="true"/>

        <!-- 主启动界面 -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 设置页面 -->
        <activity
            android:name=".SettingActivity"
            android:exported="false"/>

        <!-- 历史数据页面（列表筛选、CSV导出、ContentProvider验证） -->
        <activity
            android:name=".DataListActivity"
            android:exported="false"/>

        <!-- 后台采集服务 -->
        <service
            android:name=".SensorCollectService"
            android:exported="false"/>

    </application>
</manifest>